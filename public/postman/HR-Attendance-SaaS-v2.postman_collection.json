{
  "info": {
    "_postman_id": "7e55e4da-2d03-4b1c-90d3-7dbb8d0d8b31",
    "name": "HR Attendance SaaS APIs (v2)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "tenantId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "employeeId", "value": "", "type": "string" },
    { "key": "fromDate", "value": "2026-02-01", "type": "string" },
    { "key": "toDate", "value": "2026-02-28", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth (v2)",
      "item": [
        {
          "name": "Login (v2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  pm.collectionVariables.set('employeeId', res.user.employeeId || '');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenantId}}\",\n  \"username\": \"employee1\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token (v2)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('token', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout (v2)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Attendance (v2)",
      "item": [
        {
          "name": "Check In (v2)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"{{employeeId}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/v2/attendance/checkin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "attendance", "checkin"]
            }
          }
        },
        {
          "name": "Check Out (v2)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"employeeId\": \"{{employeeId}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/v2/attendance/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "attendance", "checkout"]
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard (v2)",
      "item": [
        {
          "name": "Employee Dashboard (v2)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v2/dashboard/employee",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v2", "dashboard", "employee"]
            }
          }
        }
      ]
    }
  ]
}

